/**
 * BankAccount.java
 *
 * Represents a bank account with encapsulated data.
 * All fields are private - external code cannot access or modify
 * balance, pin, or accountNumber directly. Access is only possible
 * through the public methods below, which enforce business rules
 * (e.g. no negative deposits, no overdraft withdrawals).
 */
public class BankAccount {
    private String accountNumber;
    private String pin;
    private double balance;

    public BankAccount(String accountNumber, String pin, double initialBalance) {
        this.accountNumber = accountNumber;
        this.pin = pin;
        this.balance = initialBalance;
    }

    /**
     * Checks whether the entered PIN matches the account's PIN.
     */
    public boolean validatePin(String enteredPin) {
        return this.pin.equals(enteredPin);
    }

    /**
     * Read-only access to balance.
     */
    public double checkBalance() {
        return balance;
    }

    public String getAccountNumber() {
        return accountNumber;
    }

    /**
     * Attempts to withdraw the given amount.
     * Returns true if successful, false if the amount is invalid
     * or exceeds the current balance.
     */
    public boolean withdraw(double amount) {
        if (amount <= 0) {
            return false; // invalid amount
        }
        if (amount > balance) {
            return false; // insufficient funds
        }
        balance -= amount;
        return true;
    }

    /**
     * Attempts to deposit the given amount.
     * Returns true if successful, false if the amount is invalid.
     */
    public boolean deposit(double amount) {
        if (amount <= 0) {
            return false; // invalid amount
        }
        balance += amount;
        return true;
    }
}
